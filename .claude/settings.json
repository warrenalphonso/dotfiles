{
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a' > /dev/tty"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "low",
  "sandbox": {
    "enabled": true,
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": ["*"]
    },
    "enableWeakerNetworkIsolation": true
  },
  "permissions": {
    "allow": [
      "WebFetch"
    ]
  }
}
