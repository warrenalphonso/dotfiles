{
  "permissions": {
    "allow": [
      "WebFetch"
    ]
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"terminalSequence\":\"\\\\u0007\"}'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"terminalSequence\":\"\\\\u0007\"}'"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": [
        "*"
      ],
      "allowLocalBinding": true
    },
    "enableWeakerNetworkIsolation": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "low"
}
